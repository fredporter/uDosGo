# Copy to demo/.wp-demo.env or export before `demo:wp-link` if you skip bootstrap.
# `npm run demo:wp-bootstrap` writes demo/.wp-demo.env automatically (gitignored).

UDOS_WP_BASE_URL=http://127.0.0.1:8080
WP_DEMO_SUBSCRIBER_USER=demo
WP_DEMO_SUBSCRIBER_PASSWORD=demoLocal-DEMO-ONLY
WP_DEMO_ADMIN_USER=udosadmin
# WP_LINK_APP_PASSWORD=   # set by wp-bootstrap (application password, no spaces)
WP_DEMO_CONTACT_ID=demo-contact-001
WP_DEMO_RESTRICTED_PATH=/empire-local-restricted/
