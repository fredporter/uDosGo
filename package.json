{
  "name": "udos-go",
  "version": "4.0.0",
  "private": true,
  "description": "uDosGo — uDos v3.0.1 local-first demo monorepo (dev process standard v4 — see docs/dev-process-v4.md)",
  "repository": {
    "type": "git",
    "url": "https://github.com/fredporter/uDosGo.git"
  },
  "homepage": "https://github.com/fredporter/uDosGo#readme",
  "bugs": {
    "url": "https://github.com/fredporter/uDosGo/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n host,thinui -c blue,magenta \"npm run dev -w @udos/host\" \"npm run dev -w @udos/thinui\"",
    "start": "npm run build && concurrently -n host,thinui -c blue,green \"npm run start -w @udos/host\" \"npm run preview -w @udos/thinui\"",
    "launch": "node scripts/launch-dev.mjs",
    "launch:open": "node scripts/launch-dev.mjs --open",
    "launch:wp": "node scripts/launch-with-wp.mjs",
    "launch:wp:open": "node scripts/launch-with-wp.mjs --open",
    "doctor": "node scripts/check-prereqs.mjs --strict",
    "doctor:docker": "node scripts/check-prereqs.mjs --strict --docker",
    "storage:init": "node scripts/init-storage.mjs",
    "wp:up": "docker compose -f infra/docker/compose.yml up -d",
    "wp:down": "docker compose -f infra/docker/compose.yml down",
    "wp:logs": "docker compose -f infra/docker/compose.yml logs -f wordpress",
    "host:start": "npm run start -w @udos/host",
    "host:dev": "npm run dev -w @udos/host",
    "thinui:dev": "npm run dev -w @udos/thinui",
    "build": "npm run validate:usxd && npm run build -w @udos/tui-ascii && npm run build -w @udos/shared && npm run build -w @udos/sdk && npm run build -w @udos/hivemind && npm run build -w @udos/host && npm run build -w @udos/thinui",
    "demo:seed": "node demo/scripts/seed.mjs",
    "demo:seed:dry": "node demo/scripts/seed.mjs --dry-run",
    "demo:seed:inbox": "node demo/scripts/seed.mjs --input sample-inputs/inbox-thread.txt",
    "demo:seed:inbox:dry": "node demo/scripts/seed.mjs --dry-run --input sample-inputs/inbox-thread.txt",
    "demo:wp-bootstrap": "node demo/scripts/wp-bootstrap.mjs",
    "demo:wp-link": "node demo/scripts/wp-link-demo.mjs",
    "validate:usxd": "node scripts/validate-usxd-surface.mjs",
    "validate:usxd:verbose": "node scripts/validate-usxd-surface.mjs --verbose",
    "validate:usxd:sibling": "node scripts/validate-usxd-sibling-lab.mjs",
    "validate:usxd:parity": "npm run validate:usxd && npm run validate:usxd:sibling",
    "doc:drift": "node scripts/check-doc-drift.mjs",
    "retro:line": "npm run build -w @udos/shared && node scripts/retro-alias-line.mjs",
    "blocktext": "node scripts/blocktext.mjs"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
