# Copy to `.env` at repo root if you use a shell tool that loads it.
# Host and ThinUI read these via their own mechanisms (see below).

# Host: persistent data (default: <repo>/.udos-data)
# UDOS_DATA_ROOT=/path/to/udos-data

# Host HTTP port (default 8787)
# PORT=8787

# WordPress base URL for Host bridge probe (default http://127.0.0.1:8080)
# UDOS_WP_BASE_URL=http://127.0.0.1:8080

# Optional: WordPress → Host webhook (set on both sides when used)
# UDOS_BRIDGE_SECRET=
